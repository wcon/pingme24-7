
<style>
  .breadcrumbWrapper{
    background-color: #f1f2f3;
    padding: 0;
    margin: 0;
    font-size:16px;
  }
</style>

{% block init %}
    {% assign title = "" %}
    {% assign welcomemessage = "" %}
    {% assign mainAdditionalCssClasses = "" -%}
{% endblock -%}
{% block initShowSideMenu %}
    {% assign showSideMenu = false %}
    {% if request.url contains "/Application/" %}
        {% assign showSideMenu = true %}
    {% endif %}
{% endblock -%}
{% fetchxml userpreferencesfetch %}
<fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false">
  <entity name="hicc_userpreference">
    <attribute name="hicc_menustyle" />
    <filter>
      <condition attribute="hicc_contact" operator="eq" value="{{user.id}}" />
    </filter>
  </entity>
</fetch>
{% endfetchxml %}
{% assign userpreferences = userpreferencesfetch.results.entities | first -%}

<main class="page-content {{mainAdditionalCssClasses}}">
  {% assign secMenuOnLeft = true %}
  {% if userpreferences and userpreferences.hicc_menustyle.Value == 672490001 %}
    {% assign secMenuOnLeft = false %}
  {% endif %}
  
  {%- block banner %}
      {% include 'hicc.portal.banner' title: title, welcomemessage: welcomemessage %}
      {% if page.url != "/" %}
      <nav id="wb-bc" property="breadcrumb" class="breadcrumbWrapper">
        <h2>You are here:</h2>
        <div class="container">
          {% include "Breadcrumbs" %}
        </div>
      </nav>
      {% endif %}
  {% endblock -%}
  
  <div class="body-content">

{% if secMenuOnLeft == true and showSideMenu == true %}
    <div class="container" style="display:flex;">
{%else%}
    <div class="container">
{%endif%}
    {% if showSideMenu == true %}
      {% if secMenuOnLeft == true %}
      <section id="wb-sec-nav" style="height:100% !important;" class="col-md-3">
        {% include 'hicc.portal.sidenav' %}
      </section>
      {% else %}
      <section id="wb-sec-nav1">
        {% include 'hicc.portal.topsecnav' %}
      </section>
      {% endif %}
    {% endif %}
      <section id="mainContent">
        {% if alertMessage %}
          {% include 'hicc.portal.alert' alertHeader: alertHeader  alertMessage: alertMessage alertType: alertType  %}
        {% endif %}
        {% include 'hicc.portal.sectionsnav' %}
      {%- block content %}
      {% endblock -%}
      </section>
    </div>
  </div>
</main>

{%- block scripts %}
{% endblock %}
