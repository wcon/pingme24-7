{% include 'AJAX Wrapper' %}
<div class="container">
    <div class="row">
        <!-- Privacy Statement -->
        {% include 'aofaa Privacy Statement' intake: false %}
        <div class="col-md-12" id="pdr_form_container" style="display: none;">
            <h1>{{ snippets['aofaa.portal.pdr.header'] }}</h1>

            <!-- Validation Error -->
            <div class="alert alert-danger hide-content" role="alert" data-id="validationErrors">
                <label class="h3">{{ snippets['aofaa.portal.validation.error.label'] }}</label>
                <ul></ul>
            </div>

            {% include 'aofaa - Submission Status' %}

            <div class="section-panel">
                <div class="section-panel-heading">
                    {{ snippets['aofaa.portal.pdr.identification.lbl'] }}
                </div>
                <div class="section-panel-body">
                    {% include 'template - form-input-field' Type:'text', CrmFieldSchema:'aofaa_projectname', CrmFieldValue: {{incidents.aofaa_projectname}}, label: {{snippets['aofaa.portal.program.project.name.lbl']}}, fieldInstruction: {{snippets['aofaa.portal.program.project.example.lbl']}}, required:true, size:'100', maxlength:'100' %}
                    {% include 'template - form-input-field' Type:'text', CrmFieldSchema:'title', CrmFieldValue: {{incidents.title}}, label:{{snippets['aofaa.portal.pdr.name.lbl']}}, fieldInstructon: {{snippets['aofaa.portal.pdr.name.instruction']}} required:true, size:'100', maxlength:'100' %}
                    {% include 'template - user-lookup' CrmFieldSchema:'aofaa_submitted_by', datatype:'incident', databind:'true' label:{{snippets['aofaa.portal.submitted.by.lbl']}}, required: true %}
                    {% include 'template - user-lookup' CrmFieldSchema:'aofaa_approving_manager', datatype:'incident', databind:'true' label:{{snippets['aofaa.portal.approving.manager.lbl']}}, required: true %}                   
                </div>
            </div>

            <div class="section-panel">
                <div class="section-panel-heading">
                    {{ snippets['aofaa.portal.pdr.details.lbl'] }}
                </div>
                <div class="section-panel-body">
                    {% include 'template - option-set' projectName:'incident', CrmFieldSchema:'aofaa_request_type', CrmFieldValue: {{incidents.aofaa_request_type}}, label:{{snippets['aofaa.portal.request.type.lbl']}}', required: true %}
                    {% include 'template - form-input-field' Type:'text', CrmFieldSchema:'aofaa_ifotherexplain', CrmFieldValue: {{incidents.aofaa_ifotherexplain}}, label: {{snippets['aofaa.portal.if.other.specify.lbl']}}, required: true, Hide: true, size:'4000', maxlength:'4000' %}
                    {% include 'template - form-input-field' Type:'date', CrmFieldSchema:'aofaa_requiredby', CrmFieldValue: {{incidents.aofaa_requiredby}}, label:{{snippets['aofaa.portal.required.by.lbl']}}, required: false, size:'100', maxlength:'100' %}
                    {% include 'template - option-set' projectName:'incident', CrmFieldSchema:'aofaa_priority', CrmFieldValue: {{incidents.aofaa_priority}}, label:{{snippets['aofaa.portal.priority.lbl']}}', required: true %}
                    {% include 'template - textarea' CrmFieldSchema:'description', CrmFieldValue: {{incidents.description}}, label: {{snippets['aofaa.portal.description.lbl']}}, fieldInstruction: {{snippets['aofaa.portal.description.instruction']}}, required:true, maxlength:'5000' %}
                    {% include 'template - option-set' projectName:'incident', CrmFieldSchema:'aofaa_risk_if_not_approved', CrmFieldValue: {{incidents.aofaa_risk_if_not_approved}}, label:{{snippets['aofaa.portal.risk.if.not.approved.lbl']}}', required: true %}
                    {% include 'template - textarea' CrmFieldSchema:'aofaa_describe_your_risk_selectionandits_impact', CrmFieldValue: {{incidents.aofaa_describe_your_risk_selectionandits_impact}}, label: {{snippets['aofaa.portal.describe.risk.selection.lbl']}}, required:true, maxlength:'5000' %}
                    {% include 'template - textarea' CrmFieldSchema:'aofaa_other_impacted_stakeholder', CrmFieldValue: {{incidents.aofaa_other_impacted_stakeholder}}, label: {{snippets['aofaa.portal.other.impacted.stakeholder.lbl']}}, fieldInstruction: {{snippets['aofaa.portal.other.impacted.instruction']}}, required:true, maxlength:'300' %}
                </div>
            </div>

            {% include 'aofaa - Document Upload' isIntake: false %}

            <div class="form-group cell">
                    <button id="SubmitForm" type="button" onclick="submitForm(`pdr`)" class="btn btn-primary">{{snippets['aofaa.portal.submit.btn']}}</button>

            </div>

        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.3.min.js"  integrity="sha256-pvPw+upLPUjgMXY0G+8O0xUf+/Im1MZjXxxgOcBQBXU="  crossorigin="anonymous"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" integrity="sha512-fD9DI5bZwQxOi7MhYWnnNPlvXdp/2Pj3XSTRrFs5FQa4mizyGLnJcN6tuvUS6LbmgN1ut+XGSABKvjN0H6Aoow==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-select@1.13.14/dist/css/bootstrap-select.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap-select@1.13.14/dist/js/bootstrap-select.min.js"></script>
<script src="~/characters-count.js"></script>
<script src="~/common.js"></script>
<script src="~/privacy.js"></script>
<script src="~/fileUpload.js"></script>
<script src="~/submitForm.js"></script>

<script>
const userId = '{{user.id}}';
let uploaded_documents = [];

$(document).ready(function() {
    loadPrivacyStatement('pdr');

    //move to a showHide library if more pop up in the future
    const if_other_field = $('#aofaa_ifotherexplain');
    if_other_field.removeClass('validate');

    $('#aofaa_request_type').on('change', function() {
        const formGroup = if_other_field.closest('div.form-group');

        if($(this).val() == 343380003) {
            if(!if_other_field.hasClass('validate'))
                if_other_field.addClass('validate');

            if(formGroup.hasClass('hide-content'))
                formGroup.removeClass('hide-content');
        }
        else {
            if(if_other_field.hasClass('validate'))
                if_other_field.removeClass('validate');

            if(!formGroup.hasClass('hide-content'))
                formGroup.addClass('hide-content');
        }
    });
});

</script>
