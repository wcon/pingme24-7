                    <button type="button"  class="btn btn-clear-picker" onclick="document.getElementById('{{CrmFieldSchema}}').showPicker()"><i class="fas fa-calendar-alt" style="color: #fff"></i></button>
                </div>
            {% endif %}
        {%endif%}
        <input type="{{Type}}" data-type="{{datatype}}" title="{{title}}" 
            class="form-control{% if required %} validate{% endif %} {{excludeSave}} {{customClass}}  {%if decimal%}decimal{%endif%}" 
            Name="{{CrmFieldSchema}}" 
