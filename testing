
{%block script %}
{% comment %} Where the script tag is called, and any script that needs to exist. {% endcomment %}
  {{ scriptcontent }}
{% endblock %}

{% unless Addbutton %}
  {% assign Addbutton = true %}
{% endunless %}

{% unless tableKey %}
  {% assign tableKey = TableId %}
{% endunless %}

{% if hidelabel == nil %}
  {% assign hidelabel = true %}
{% endif %}


<div class="form-group cell{%if Hide %} hide-content {% endif %}">
    <label class="h3 control-label {% if hidelabel %}hide-content{% endif %}" for="{{tableId}}_table">
       <span>{{TableTitle}}</span>
    </label>
    {% if Addbutton %}
      {% if editable%}
        <button  type="button" class="btn-sm btn btn-primary "data-toggle="modal" data-target="#{{ModalId}}_modal" data-tableKey="{{tableKey}}" data-entity="{{tableEntity}}"  style="margin-bottom: 1em;"><span class="fa fa-plus"></span> {{Addtitle}}</button>
      {% endif %}
    {% endif %}
    <table id="{{TableId}}_table" data-parent_table="cdm_app" data-modal="{{ModalId}}_modal" data-tableKey="{{tableKey}}" data-entity="{{tableEntity}}"  class="table table-hover table-striped table-bordered{% if required %} validate{% endif %}" >
      <thead>
        <tr>
          {% block TableHeaders %}
          {{Tableheader}}
          {% endblock %}
          {%if editable %}<th style="width: 6em;">Options</th>{%endif%}
        </tr>
      </thead>
      <tbody>    
      </tbody> 
    </table>
  
  </div>
  {% block Modal %}
    {% if editable%}
      {% if modal %}
        {% include 'Template - Modal', ModalId:ModalId, ModalContent:Modalcontent, ModalTitle:ModalTitle %}
      {% endif %}
    {%endif%}
  {% endblock %}

  {% assign tableKey = nil %}
  {% assign hidelabel = nil %}
