//If the INFC namespace object is not defined, create it
if (typeof INFC === "undefined") {
	INFC = {};
}
var INFC = INFC || {};
INFC.Utilities = INFC.Utilities || {};

INFC.Utilities = {
	setFieldValues: function (formContext, fieldArray, valueToBeSet) {
		var internalArray = [];
		if (fieldArray.constructor !== Array) {
			internalArray[0] = fieldArray;
		}
		else {
			internalArray = fieldArray
		}
		for (var i = 0; i < internalArray.length; i++) {
			if (formContext.getAttribute(internalArray[i]) !== null && formContext.getAttribute(internalArray[i]) !== "undefined") {
				formContext.getAttribute(internalArray[i]).setValue(valueToBeSet);
			}
			else {
				console.log("Unable to clear field visibility: " + internalArray[i])
			}
		}
	},
	SetFieldVisibility: function (formContext, fieldArray, visibility, optionalClearValue) {
		var internalArray = [];
		if (fieldArray.constructor !== Array) {
			internalArray[0] = fieldArray;
		}
		else {
			internalArray = fieldArray
		}
		for (var i = 0; i < internalArray.length; i++) {
			if (!this.IsNullOrUndefined(formContext.getControl(internalArray[i]))) {
				if (optionalClearValue) {
					formContext.getAttribute(internalArray[i]).setValue(null)
				}
				formContext.getControl(internalArray[i]).setVisible(visibility);
			}
			else {
				console.log("Unable to set field visibility: " + internalArray[i])
			}
		}
	},
	setQuickViewVisibility: function (executionContext, quickViewName, visibilityState) {
		var formContext = executionContext.getFormContext();
		if (!this.IsNullOrUndefined(formContext._ui.quickForms.get(quickViewName))) {
			formContext._ui.quickForms.get(quickViewName).setVisible(visibilityState);
		}
		else {
			console.log("Unable to set visiblity for control with name: " + quickViewName)
		}
	},
	IsNullOrUndefined: function (value) {
		return typeof value === "undefined" || value === null;
	},
	setFieldDisabledState: function (formContext, fieldArray, disabledState) {
		var internalArray = [];
		if (fieldArray.constructor !== Array) {
			internalArray[0] = fieldArray;
		}
		else {
			internalArray = fieldArray
		}
		for (var i = 0; i < internalArray.length; i++) {
			if (!this.IsNullOrUndefined(formContext.getControl(internalArray[i]))) {
				formContext.getControl(internalArray[i]).setDisabled(disabledState);
			}
			else {
				console.log("Unable to change disabled state for: " + internalArray[i])
			}
		}
	},
	setReviewedBy: function (executionContext, reviewedByAttribute) {
		var formContext = executionContext.getFormContext();
		if (reviewedByAttribute !== "" && !INFC.Utilities.IsNullOrUndefined(reviewedByAttribute)) {
			var userName = Xrm.Utility.getGlobalContext().userSettings.userName
			var currentReviewedByValue = formContext.getAttribute(reviewedByAttribute).getValue();
			if (userName !== currentReviewedByValue) {
				INFC.Utilities.setFieldValues(formContext, reviewedByAttribute, userName);
			}
			else {
				console.log("Reviewed by is current user")
			}
		}
		else {
			console.log("Reviewed by target field not found")
		}
	},

	setReviewedByLookup: function (executionContext, reviewedByAttribute) {
		var formContext = executionContext.getFormContext();
		if (reviewedByAttribute !== "" && !INFC.Utilities.IsNullOrUndefined(reviewedByAttribute)) {
			var globalContext = Xrm.Utility.getGlobalContext();
			var currentUser = new Array();
			currentUser[0] = new Object();
			currentUser[0].entityType = "systemuser";
			currentUser[0].id = globalContext.userSettings.userId;
			currentUser[0].name = globalContext.userSettings.userName;
			var currentReviewedByValue = formContext.getAttribute(reviewedByAttribute).getValue();
			if (currentUser !== currentReviewedByValue) {
				INFC.Utilities.setFieldValues(formContext, reviewedByAttribute, currentUser);
			}
			else {
				console.log("Reviewed by is current user")
			}
		}
		else {
			console.log("Reviewed by target field not found")
		}
	},

	setRequiredState: function (formContext, fieldArray, isRequired) {
		var internalArray = [];
		if (fieldArray.constructor !== Array) {
			internalArray[0] = fieldArray;
		}
		else {
			internalArray = fieldArray
		}

		var requirementLevel = "";

		if (isRequired == true) {
			requirementLevel = "required";
		}
		else if (isRequired == false) {
			requirementLevel = "none";
		}
		else {
			console.log("Value provided in isRequired variable is invalid")
		}
		for (var i = 0; i < internalArray.length; i++) {
			if (requirementLevel != "" && !this.IsNullOrUndefined(formContext.getAttribute(internalArray[i]))) {
				formContext.getAttribute(internalArray[i]).setRequiredLevel(requirementLevel);
			}
			else {
				console.log("Unable to change requirment state for: " + internalArray[i])
			}
		}
	},
	checkFieldExistAndRetrieveField: function (formContext, fieldName) {
		var field;
		if (fieldName !== null && fieldName !== undefined) {
			field = formContext.getAttribute(fieldName);
			if (field !== null) {
				return field;
			}
		}
	},
	addReviewEventListener: function (executionContext, sourceFieldName, reviewedByAttribute) {
		var formContext = executionContext.getFormContext();
		var sourceField = this.checkFieldExistAndRetrieveField(formContext, sourceFieldName)
		if (sourceField !== null && sourceField !== undefined && reviewedByAttribute !== null && reviewedByAttribute !== undefined) {
			sourceField.addOnChange(function () { INFC.Utilities.setReviewedBy(executionContext, reviewedByAttribute) })
		}
	},
	addReviewEventListenerforLookup: function (executionContext, sourceFieldName, reviewedByAttribute) {
		var formContext = executionContext.getFormContext();
		var sourceField = this.checkFieldExistAndRetrieveField(formContext, sourceFieldName)
		if (sourceField !== null && sourceField !== undefined && reviewedByAttribute !== null && reviewedByAttribute !== undefined) {
			sourceField.addOnChange(function () { INFC.Utilities.setReviewedByLookup(executionContext, reviewedByAttribute) })
		}
	},
	addGenericEventListener: function (executionContext, targetFieldName, eventFunction, eventArgument1, eventArgument2) {
		var formContext = executionContext.getFormContext();
		var targetField = formContext.getAttribute(targetFieldName);

		if (!this.IsNullOrUndefined(targetField) && !this.IsNullOrUndefined(eventArgument1) && !this.IsNullOrUndefined(eventArgument2)) {
			targetField.addOnChange(function () { eventFunction(executionContext, eventArgument1, eventArgument2) });
		}
		else if (!this.IsNullOrUndefined(targetField) && !this.IsNullOrUndefined(eventArgument1)) {
			targetField.addOnChange(function () { eventFunction(executionContext, eventArgument1) });
		}
		else if (!this.IsNullOrUndefined(targetField)) {
			targetField.addOnChange(function () { eventFunction(executionContext) });
		}
		else {
			console.log("Unable to add event to field with name: " + targetFieldName);
		}
	}
}
