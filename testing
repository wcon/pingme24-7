{% if maxlength %}
    {%comment%} If maxvalue is not provided and this is a number field, we generate it so the maxvalue function can work {%endcomment%}
    {% if Type == "number" %}
        {% unless maxvalue %}
            {% assign tmpMaxValue = '' %}
            {% for i in (1..maxlength) %}
                {% assign tmpMaxValue = tmpMaxValue | append: '9' %}
            {% endfor %}
            {% assign maxvalue = tmpMaxValue | floor %}
        {% endunless %}
    {% endif %}
{%else%}
    {% if datatype == "currency" %}
            {% assign maxlength = '14' %}
    {%else%}
        {% assign maxlength = '100' %}
    {% endif %}
{% endif %}

{% if maxvalue %}
{%else%}
    {% if datatype == "currency" %}
            {% assign maxvalue = '99999999999' %}
    {%endif%}
{%endif%}


{% if size %}{%else%}{% assign size = '130' %}{%endif%}


{%if inputOnly == "Yes" %}
    {% if disabled %}
        <p class="mrgn-lft-sm {{customClass}}" id="{{CrmFieldSchema}}" data-id="{{dataid}}">{{CrmFieldValue}}</p>
    {%else%}
        <input type="{{Type}}" data-type="{{datatype}}" title="{{title}}" 
            class="form-control{% if required %} validate{% endif %} {{excludeSave}} {{customClass}}  {%if decimal%}decimal{%endif%}" 
            Name="{{CrmFieldSchema}}" 
            {% if size %}size="{{size}}"{% endif %} 
            {% if Type == "date" %} 
                {% if mindate %} min="{{mindate}}" {% else %} min="1970-01-01" {% endif %} 
                {% if maxdate %} max="{{maxdate}}" {% else %} max="3000-12-31" {% endif %} 
            {%else%}
                {% if min %}
                    min="{{min}}"
                    {% if Type == "number" %} 
                        oninput="this.value = Math.abs(this.value)"
                    {% endif %} 
                {% endif %} 
            {% endif %} 
            {% if maxvalue %}
                maxvalue="{{maxvalue}}"
                oninput="setMaxValue(this)" 
            {% endif %} 
            {% if maxlength %}maxlength="{{maxlength}}"{% endif %} 
            value="{{CrmFieldValue}}" 
            id="{{CrmFieldSchema}}" 
            {% if oninput %}
                oninput="{{oninput}}" 
            {%endif%}
            {% if Type == "number" and decimal == false %}onkeypress="preventDecimals(event)" onpaste="preventDecimals(event)" {% endif %}
            {% if readonly %} {{readonly}} {% endif %} 
        >
    {%endif%}
{%else%}

<div class="form-group cell {%if Hide %}hide-content{%endif %}">
    <label class="control-label{%if required %} required{%endif%}" for="{{CrmFieldSchema}}"><span>{{label}}</span>{%if ToolTip == "Yes"%} <span class="glyphicon glyphicon-info-sign" data-toggle="tooltip" data-placement="bottom" title="{{title}}"></span>{%endif %} {%if required  %}{{snippets['infc.portal.required']}}{%endif%}</label>
