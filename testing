
<div id="PrivacyContainer" style="padding-top: 15%">
    <h2>{{snippets['infc.portal.privacy.title']}}</h2>
    {{snippets['infc.portal.privacy.statement']}}
    <br><br><br>
    <div class="form-group cell">
        <label class="control-label required" for="infc_privacystatement">{{snippets['infc.portal.privacy.statement.agree']}} {{snippets['infc.portal.required']}}</label>
        <div title="" id="infc_privacystatement" data-type="" class="form-group cell validate" data-target="">
            <div class="radio-inline">
                <input type="radio" id="infc_privacystatement_yes" name="infc_privacystatement" class="custom-control-input excludeSave " aria-required="true">
                <label class="custom-control-label" for="infc_privacystatement_yes">{{snippets['infc.portal.yes']}}</label>
            </div>
            <div class="radio-inline">
                <input type="radio" id="infc_privacystatement_no" name="infc_privacystatement" class="custom-control-input excludeSave " aria-required="true">
                <label class="custom-control-label" for="infc_privacystatement_no">{{snippets['infc.portal.no']}}</label>
            </div>
        </div>
    </div>
    <div class="form-group cell">
        <button type="button" class="btn btn-primary" onclick="history.back()">{{snippets['infc.portal.go.back.btn']}}</button>
        <button id="PrivacyButton" type="button" class="btn btn-primary" disabled>{{snippets['infc.portal.next.btn']}}</button>
    </div>
</div>

