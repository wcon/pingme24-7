
{%if required or validate%}
    {% assign required = true %}
{% endif %}

{% if CustomSchema %}
    {% assign Schema = CustomSchema %}
{%else%}
    {% assign Schema = CrmFieldSchema %}
{%endif%}


{% fetchxml optionsets %}
<fetch>
    <entity name="stringmap">
    <attribute name="attributevalue" />
    <attribute name="value" />
    <attribute name="langid" />
    <attribute name="objecttypecode" />
    <filter type="and">
		<condition attribute="attributename" operator="eq" value="{{CrmFieldSchema}}" />
	</filter>
</entity>
</fetch>
{%endfetchxml%}


</script>
{% capture option_value_array %}{% endcapture %}



{% if disabled %}
	<div class="form-group cell{%if Hide %} hide-content{%endif %}">
		<label class="control-label{%if required %} required{%endif%}"  for="{{Schema}}"><span>{{label}}</span>{%if required %} {{snippets['infc.portal.required']}}{%endif%}</label>
		<p class="mrgn-lft-sm {{customClass}}" id="{{Schema}}">{{option_value}}</p>
	</div>
{%else%}

    {%if selectOnly %}
        <div class="input-group">
        <select class="form-control{%if required %} validate{%endif%} {{excludeSave}} {{customClass}}" name="{{CrmFieldSchema}}" id="{{CrmFieldSchema}}" data-none-selected-text=" " aria-label="Default select example"{%if multiple %} multiple{%endif%} {{disabled}}>
            {%for optionset in optionsets.results.entities %}
                {% if optionset.objecttypecode == projectName %}
                    {% if website.selected_language.name == "English" %}  
                        {% if optionset.langid =="1033"%}
                        <option value="{{optionset.attributevalue}}">{{optionset.value}}</option>
                        {%endif%}
                    {%else%}
                        {%if optionset.langid == "1036"%}
                        <option value="{{optionset.attributevalue}}">{{optionset.value}}</option>
                        {%endif%}
                    {%endif%}
                {%endif%}
            {%endfor%}
        </select>
            <div class="input-group-btn">
                <button type="button" class="btn btn-default" onclick="clear_selectpicker($(this))"><i class="fas fa-times"></i></button>
            </div>
            </div>
    {%else%}
    <div class="form-group cell{%if Hide %} hide-content{%endif %}">
        <label class="control-label{%if required %} required{%endif%}" for="{{Schema}}"><span>{{label}}</span>{%if ToolTip == "Yes"%} <span class="glyphicon glyphicon-info-sign" data-toggle="tooltip" data-placement="bottom" title="{{title}}"></span>{%endif %} {%if required %}{{snippets['infc.portal.required']}}{%endif%}</label>
        {% if fieldInstruction %}
            <p class="fieldInstruction" style="font-size: 12px;">{{ fieldInstruction }}</p>  
        {% endif %}
        <div class="input-group">
        <select class="form-control{%if required %} validate{%endif%} {{excludeSave}} {{customClass}}" name="{{CrmFieldSchema}}" id="{{CrmFieldSchema}}" data-none-selected-text=" " aria-label="Default select example"{%if multiple %} multiple{%endif%} {{disabled}}>
            {%for optionset in optionsets.results.entities %}
                {% if optionset.objecttypecode == projectName %}
                    {% if website.selected_language.name == "English" %}  
                        {% if optionset.langid =="1033"%}
                        <option value="{{optionset.attributevalue}}">{{optionset.value}}</option>
                        {%endif%}
                    {%else%}
                        {%if optionset.langid == "1036"%}
                        <option value="{{optionset.attributevalue}}">{{optionset.value}}</option>
                        {%endif%}
                    {%endif%}
                {%endif%}
            {%endfor%}
        </select>
        <div class="input-group-btn">
            <button type="button"  class="btn btn-clear-picker" onclick="clear_selectpicker($(this))"><i class="fas fa-times"></i></button>
        </div>
        </div>
    </div>
    {%endif%}
    {% if noJS %}
    {%else%}
    <script>
        $( document ).ready(function() {
            $('#{{Schema}}').selectpicker();
            {% if CrmFieldValue.value %}
            $('#{{Schema}}').selectpicker('val', '{{CrmFieldValue.value}}');
            {%else%}
            $('#{{Schema}}').selectpicker('val', [{% for item in CrmFieldValue %} {%if forloop.last == false %} '{{item.value}}', {%else%} '{{item.value}}' {%endif%} {%endfor%}]);
            {%endif%}
            $('.dropdown-menu.open').css('max-width','100%');
            {% if Disabled %}
            $('#{{Schema}}').prop('disabled', true);
            $('#{{Schema}}').selectpicker('refresh');
            {%endif%}
        });
    </script>
    {%endif%}
{%endif%}

{% comment %}
    This is to clear the assigned variable
{% endcomment %}

{% assign required = nil %}
{% assign Schema = nil %}
